# Copy this file to .env and fill values for your own environment.
# Do not commit real database credentials.

# PostgreSQL
DATABASE_PROVIDER="postgresql"
POSTGRES_DATABASE_URL="postgresql://user:password@host:5432/database"
POSTGRES_DEMO_DATABASE_URL="postgresql://user:password@host:5432/database"
POSTGRES_SCHEMA="rps"

# REST API
DATABASE_URL="postgresql://user:password@host:5432/database"
API_PORT="3001"
CLIENT_ORIGIN="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:3001/api"

# SQL Server
SQLSERVER_DATABASE_URL="sqlserver://localhost:1433;database=roll_production_system;user=sa;password=your_password;encrypt=true;trustServerCertificate=true"

# General app config
APP_NAME="Roll Production System"
APP_TIMEZONE="Asia/Jakarta"
